  "settings.cheat_health_max": "Health always MAX",
  "settings.cheat_fatigue_max": "Fatigue always MAX",
  "settings.cheat_spell_max": "Spell points always MAX",
  "settings.bonus_pts_pool": "Bonus attribute points pool",
  "settings.cheat_note": "Enabling cheat alone does nothing; turn on the sub-settings individually. Always-MAX (Health/Fatigue/Spell Pts) and the Set-value buttons work with cheat ON only (Status change is NOT required). 'Status change' enables attribute editing; the bonus pool requires 'Status change' ON. 'HP invincible mode' is the legacy alias for Health & Spell Pts always-MAX and remains active.",
  "settings.tab_map": "Map",
  "settings.group_map_settings": "Map Display Settings",
  "settings.map_wall_line_of_sight": "Wall line-of-sight on the map",
  "settings.map_wall_line_of_sight_tip": "When ON, the map records cells behind walls just like the original Arena. When OFF (default), unexplored cells behind walls are NOT recorded. Cells already recorded on the map remain visible regardless of this setting.",
  "settings.map_show_unexplored_floor": "Show floor for unexplored area",
  "settings.map_show_unexplored_floor_tip": "When ON, the entire map area is filled with the parchment color (the full map size is visible). When OFF (default), only revealed cells show the floor color, so the map size is hidden.",
  "settings.map_center_on_player": "Center on character",
  "settings.map_center_on_player_tip": "When ON (default), the map auto-centers on the character as they move. While stopped, you can pan freely (auto-centering resumes on next move). When OFF, the map is always pan-controlled manually.",
  "settings.map_show_grid": "Show grid lines",
  "settings.map_show_grid_tip": "When ON (default), grid lines are drawn at cell boundaries. With unexplored-floor OFF, grid lines only appear around revealed cells, keeping the map size hidden.",
  "settings.map_show_chunk_grid": "Show chunk boundaries",
  "settings.map_show_chunk_grid_tip": "When ON (default), the field (C3) map emphasizes chunk (64-tile) boundaries with a thicker colored line so you can tell chunks apart. Shown even when fully zoomed out (independent of regular grid lines).",
  "settings.map_show_chunk_coords": "Show chunk coordinates",
  "settings.map_show_chunk_coords_tip": "When ON (default), each chunk on the field (C3) map is labeled with its chunk coordinate so you can read off where you are.",
  "settings.map_show_recenter_lines": "Show re-center boundaries",
  "settings.map_show_recenter_lines_tip": "When ON, dashed lines split each chunk into quadrants at its center on the field (C3) map. These mark where the 2x2 view window re-centers (shifts by one chunk), a useful cue even outside the 64x64 grid. Default OFF.",
  "settings.map_chunk_coord_font_size": "Chunk coordinate font size",
  "settings.map_chunk_coord_font_size_tip": "Font size (pt) for the chunk coordinate labels on the field (C3) map.",
  "settings.wilderness_compact_view": "Wilderness compact view",
  "settings.wilderness_compact_view_tip": "When ON, the wilderness map matches the in-game automap (= hides fine edge geometry like farms/grass). When OFF (default), all RMD voxels are rendered, showing terrain visible in 3D that the in-game automap omits.",
  "settings.group_field_extended": "Field extended display",
  "settings.map_extended_display": "Enable extended display",
  "settings.map_extended_display_tip": "Master switch for the field (C3) map's extended display. When OFF, the map matches the in-game automap (roads and walls share one color, edges hidden, no extra entrances). When ON, the items below take effect; turning all of them OFF looks the same as OFF. Crypt/tower/dungeon entrances (red) are shown in the game's automap too, so they are always drawn red regardless of these toggles.",
  "settings.wild_distinguish_road": "Distinguish road from wall",
  "settings.wild_distinguish_road_tip": "When ON (default), walkable roads are drawn in a distinct color (light brown) to separate them from impassable buildings/walls (dark brown). When OFF, roads and walls share one color like the in-game automap.",
  "settings.wild_show_edge": "Show wall edges",
  "settings.wild_show_edge_tip": "When ON (default), wall edge geometry is also drawn. When OFF, edges are hidden like the in-game automap.",
  "settings.wild_distinguish_edge": "Distinguish fences/hedges/gardens",
  "settings.wild_distinguish_edge_tip": "When ON (default), fences, hedges and gardens are drawn as category-colored lines along their orientation (vertical/horizontal) instead of filled blocks, so they read as fences. Only active when 'Show wall edges' is ON. When OFF, edges are filled uniformly as before.",
  "settings.wild_show_crops": "Show crops",
  "settings.wild_show_crops_tip": "When ON (default), corn (golden-green with ear marks) is filled in a crop color, and the farmland ground is tinted the same golden-green to distinguish it. When OFF, the ground is drawn in its normal color as before.",
  "settings.wild_show_all_entrances": "Show all building entrances",
  "settings.wild_show_all_entrances_tip": "Also marks house/tavern/temple/city-gate entrances red. When ON they are shown; when OFF only crypt/tower/dungeon are red, like the in-game automap. Crypt/tower/dungeon entrances are always red regardless of this setting.",
  "settings.wild_show_static_flats": "Show landmarks (trees, bushes, etc.)",
  "settings.wild_show_static_flats_tip": "Shows field landmarks (trees, bushes, rocks, graves, ruins) as simplified per-type marks (tree = green triangle, bush = green dot, rock = gray diamond, grave = cross, ruin = square). Marks are overlaid without filling the map. OFF by default (trees are numerous and can clutter the map); turn ON when you want to inspect landmarks.",
  "settings.translate_fallback_screen": "Fallback display on idle",
  "settings.translate_fallback_screen_tip": "What to show across the Translate tab when the game is in exploration mode with no translation (original text is —). If the game shows a Status or Map screen, that takes priority.",
  "settings.translate_fallback_none": "Don't replace (stay on Translate)",
