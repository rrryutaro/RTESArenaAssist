  "text_corrections": [
    {
      "id": "title_postposition_singleword",
      "description": "敬称後置: 「卿・〇〇」「夫人・〇〇」「伯爵・〇〇」「男爵・〇〇」を「〇〇卿」等に変換",
      "rationale": "日本語の敬称は名前後置が自然（公式 TES5 翻訳『ハーコン卿』等に準拠）。Arena オリジナル英語の前置 'Lord Name' を直訳すると不自然になるため、最終出力で語順補正する",
      "pattern": "(卿|夫人|伯爵|男爵)・([^\\sぁ-ん、。？！「」]+)",
      "replace": "\\2\\1"
    }
  ],
  "placeholder_preprocessing": {
    "placeholders": {
      "nk": [
        {
          "id": "strip_english_indefinite_article",
          "description": "英語不定冠詞 a/an を剥がして items.json/key_materials を正しく引けるようにする",
          "pattern": "^(?:a|an) (?=[A-Z])",
          "replace": ""
        }
      ],
      "ni": [
        {
          "id": "strip_english_indefinite_article",
          "description": "英語不定冠詞 a/an を剥がして items.json を正しく引けるようにする (汎用アイテム名)",
